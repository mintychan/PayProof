# RPC Endpoints
NEXT_PUBLIC_PROTOCOL_RPC_URL="https://protocol-rpc-placeholder"
NEXT_PUBLIC_SEPOLIA_COPROCESSOR_RPC_URL="https://sepolia-coprocessor-placeholder"
NEXT_PUBLIC_FHE_RPC_URL="https://sepolia.gateway.tenderly.co"
NEXT_PUBLIC_SEPOLIA_RPC_URL="https://ethereum-sepolia-rpc.publicnode.com"

# For local Hardhat development, set this to "1" to use fallback encryption (no Gateway/Relayer needed)
# For Sepolia testnet, leave unset or set to "0"
NEXT_PUBLIC_FHE_FALLBACK="0"

# Encrypted Payroll Contracts (fhEVM) - deployed on Sepolia
# EncryptedPayroll - manages confidential payroll streams with encrypted rates
NEXT_PUBLIC_PAYPROOF_PAYROLL_CONTRACT="0x6fa3a1adC06fefeA333A1ce82B4e36Fac539ed9D"
# IncomeOracle - provides proof-of-income attestations using fhEVM
NEXT_PUBLIC_PAYPROOF_ORACLE_CONTRACT="0xE8C06A8a5fACC90C88D81FF0377b8510847C1717"

# Optional: point to the hosted subgraph for employer dashboards
NEXT_PUBLIC_PAYPROOF_SUBGRAPH_URL="https://api.studio.thegraph.com/query/1704881/pay-proof/v0.1.1"
